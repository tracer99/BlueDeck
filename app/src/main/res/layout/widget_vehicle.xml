<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_vehicle_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/widget_text_primary_dark"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/widget_lock_status"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:background="@drawable/widget_battery_panel_background"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="Doors Locked"
            android:textColor="#FFB000"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:includeFontPadding="false" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="3dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/widget_battery_panel_background"
            android:gravity="center_vertical"
            android:padding="6dp">

            <LinearLayout
                android:layout_width="74dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/widget_battery_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Battery"
                    android:textColor="#99FFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/widget_battery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <TextView android:layout_width="6dp" android:layout_height="1dp" android:text="" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/widget_range"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Range —"
                        android:textColor="#C8D7FF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/widget_battery_meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="Updated —"
                        android:textColor="#99FFFFFF"
                        android:textSize="8sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/widget_battery_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="7dp"
                    android:layout_marginTop="3dp"
                    android:indeterminate="true"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/widget_battery_progress" />

                <TextView
                    android:id="@+id/widget_battery_substatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="All Systems Normal"
                    android:textColor="#E8EDF5"
                    android:textSize="8sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="3dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_charging"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/widget_battery_panel_background"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="All Systems Normal"
                    android:textColor="#AFC7FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />

                <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />

                <TextView
                    android:id="@+id/widget_detail_one"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/widget_battery_panel_background"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="Doors/Hood/Trunk Closed"
                    android:textColor="#E8EDF5"
                    android:textSize="11sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="3dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_detail_two"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/widget_battery_panel_background"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="Climate Control Off"
                    android:textColor="#E8EDF5"
                    android:textSize="11sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />

                <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />

                <TextView
                    android:id="@+id/widget_detail_three"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/widget_battery_panel_background"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="No Vehicle Alerts"
                    android:textColor="#E8EDF5"
                    android:textSize="11sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="3dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_detail_four"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/widget_battery_panel_background"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="Updated —"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />

                <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />

                <TextView
                    android:id="@+id/widget_updated"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/widget_battery_panel_background"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:text="Doors Locked"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginTop="3dp">

        <TextView
            android:id="@+id/widget_refresh_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/widget_action_background"
            android:gravity="center"
            android:text="Refresh"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:includeFontPadding="false" />

        <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />

        <TextView
            android:id="@+id/widget_lock_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/widget_action_background"
            android:gravity="center"
            android:text="Lock"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:includeFontPadding="false" />

        <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />

        <TextView
            android:id="@+id/widget_unlock_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/widget_action_background"
            android:gravity="center"
            android:text="Unlock"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:includeFontPadding="false" />

        <TextView android:layout_width="4dp" android:layout_height="1dp" android:text="" />

        <TextView
            android:id="@+id/widget_climate_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/widget_action_background"
            android:gravity="center"
            android:text="Climate"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:includeFontPadding="false" />
    </LinearLayout>
</LinearLayout>
