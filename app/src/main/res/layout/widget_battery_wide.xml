<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_dashboard_background"
    android:padding="9dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_vehicle_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="#F0F4FA"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_lock_status"
            android:layout_width="wrap_content"
            android:layout_height="21dp"
            android:background="@drawable/widget_battery_panel_background"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:text="—"
            android:textColor="#FFFFA726"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_battery_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:orientation="vertical"
        android:background="@drawable/widget_battery_panel_background"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_battery"
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:text="—%"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:includeFontPadding="false" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/widget_range"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="Range —"
                    android:textColor="#D0D6E0"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/widget_updated"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:gravity="end"
                    android:text="Open app to refresh"
                    android:textColor="#99FFFFFF"
                    android:textSize="9sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_battery_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:layout_marginTop="5dp"
            android:indeterminate="true"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_battery_progress" />

        <TextView
            android:id="@+id/widget_charging"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minHeight="22dp"
            android:text="Tap to open app"
            android:textColor="#FF35F2B6"
            android:textSize="10sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_detail_one"
                android:layout_width="0dp"
                android:layout_height="18dp"
                android:layout_weight="1"
                android:background="@drawable/widget_battery_panel_background"
                android:gravity="center_vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="Closed"
                android:textColor="#E8EDF5"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView android:layout_width="5dp" android:layout_height="1dp" android:text="" />

            <TextView
                android:id="@+id/widget_detail_two"
                android:layout_width="0dp"
                android:layout_height="18dp"
                android:layout_weight="1"
                android:background="@drawable/widget_battery_panel_background"
                android:gravity="center_vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="Climate off"
                android:textColor="#E8EDF5"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_detail_three"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_battery_panel_background"
            android:gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="No alerts"
            android:textColor="#E8EDF5"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_refresh_button"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_action_background"
            android:gravity="center"
            android:text="Refresh"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
